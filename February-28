# Load CIFAR-10 dataset as an example
(train_images, train_labels), (test_images, test_labels) = keras.datasets.cifar10.load_data()
train_images_nn = train_images.astype('float32') / 255.0
test_images_nn = test_images.astype('float32') / 255.0

model = Sequential()
model.add(layers.Conv2D(10, (3, 3), activation='relu', input_shape=(32,32,3)))
model.add(layers.MaxPooling2D((2,2)))
model.add(layers.Conv2D(32, (3, 3), activation='relu'))
model.add(layers.MaxPooling2D((2,2)))
model.add(layers.Flatten())
model.add(layers.Dense(120, activation='relu'))
model.add(layers.Dense(100, activation='relu'))
model.add(layers.Dense(10, activation='softmax'))
model.compile(optimizer='adam', loss='sparse_categorical_crossentropy', metrics=['accuracy'])
history = model.fit(train_images_nn, train_labels, epochs=1, batch_size=4, validation_split=0.2)

test_loss, test_acc = model.evaluate(test_images_nn, test_labels)
print(f'Test accuracy: {test_acc}')
print(f'Test loss: {test_loss}')

correct_class = list(0. for i in range(10))
total_class = list(0. for i in range(10))
class_names = ['airplane', 'automobile', 'bird', 'cat', 'deer',
			   'dog', 'frog', 'horse', 'ship', 'truck']
prediction = model.predict(test_images_nn)
predicted_labels = np.argmax(prediction, axis=1)
for i in range(len(test_labels)):
	label = test_labels[i][0]
	correct_class[label] += (predicted_labels[i] == label)
	total_class[label] += 1
for i in range(10):
	print('Accuracy of %s : %2d %%' % (class_names[i] , 100 * correct_class[i] / total_class[i]))
	
